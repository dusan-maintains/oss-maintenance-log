{
  "name": "oss-health-scan",
  "version": "1.2.0",
  "description": "Scan your package.json for abandoned, unmaintained, or unhealthy npm dependencies. Get health scores (0-100) for every dependency. SARIF output for GitHub Code Scanning. Zero external dependencies.",
  "main": "./lib/api.js",
  "exports": {
    ".": "./lib/api.js",
    "./scoring": "./lib/scoring.js",
    "./sarif": "./lib/sarif.js"
  },
  "bin": {
    "oss-health-scan": "./bin/scan.js"
  },
  "keywords": [
    "npm",
    "dependencies",
    "health",
    "abandoned",
    "unmaintained",
    "security",
    "audit",
    "maintenance",
    "oss",
    "scanner",
    "supply-chain",
    "deprecated",
    "dead-packages"
  ],
  "author": "dusan-maintains",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dusan-maintains/oss-maintenance-log.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/dusan-maintains/oss-maintenance-log/tree/main/cli#readme",
  "bugs": {
    "url": "https://github.com/dusan-maintains/oss-maintenance-log/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md"
  ]
}
