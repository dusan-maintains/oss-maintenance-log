{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health Scores",
  "description": "Weighted health scoring (0-100) per tracked package. Generated by compute-health-scores.ps1.",
  "type": "object",
  "required": ["generated_at_utc", "summary", "scores"],
  "properties": {
    "generated_at_utc": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["total_projects", "average_health_score", "critical", "warning", "healthy"],
      "properties": {
        "total_projects": { "type": "number", "minimum": 0 },
        "average_health_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "critical": { "type": "number", "minimum": 0 },
        "warning": { "type": "number", "minimum": 0 },
        "healthy": { "type": "number", "minimum": 0 }
      }
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner", "repo", "health_score", "risk_level", "breakdown"],
        "properties": {
          "owner": { "type": "string" },
          "repo": { "type": "string" },
          "repo_url": { "type": "string" },
          "package": { "type": ["string", "null"] },
          "health_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "risk_level": { "type": "string", "enum": ["critical", "warning", "healthy"] },
          "breakdown": {
            "type": "object",
            "required": ["maintenance", "community", "popularity", "risk"],
            "properties": {
              "maintenance": {
                "type": "object",
                "required": ["weight", "score"],
                "properties": {
                  "weight": { "type": "number" },
                  "score": { "type": "number", "minimum": 0, "maximum": 10 }
                }
              },
              "community": {
                "type": "object",
                "required": ["weight", "score"],
                "properties": {
                  "weight": { "type": "number" },
                  "score": { "type": "number", "minimum": 0, "maximum": 10 }
                }
              },
              "popularity": {
                "type": "object",
                "required": ["weight", "score"],
                "properties": {
                  "weight": { "type": "number" },
                  "score": { "type": "number", "minimum": 0, "maximum": 10 }
                }
              },
              "risk": {
                "type": "object",
                "required": ["weight", "score"],
                "properties": {
                  "weight": { "type": "number" },
                  "score": { "type": "number", "minimum": 0, "maximum": 10 }
                }
              }
            }
          },
          "stars": { "type": "number" },
          "npm_downloads_last_week": { "type": "number" },
          "status_label": { "type": "string" }
        }
      }
    }
  }
}
