{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pipeline Manifest",
  "description": "Run-level truth file for pipeline health. Tracks step status, per-repo freshness, and error details.",
  "type": "object",
  "required": ["run_started_at_utc", "run_status", "summary"],
  "properties": {
    "schema_version": { "type": "number" },
    "run_started_at_utc": { "type": "string" },
    "run_completed_at_utc": { "type": "string" },
    "run_status": { "type": "string", "enum": ["success", "partial", "failed"] },
    "config_version": { "type": "number" },
    "summary": {
      "type": "object",
      "required": ["total_steps", "successful_steps", "failed_steps", "skipped_steps"],
      "properties": {
        "total_steps": { "type": "number", "minimum": 0 },
        "successful_steps": { "type": "number", "minimum": 0 },
        "failed_steps": { "type": "number", "minimum": 0 },
        "skipped_steps": { "type": "number", "minimum": 0 },
        "tracked_repositories": { "type": "number", "minimum": 0 },
        "fresh_repositories": { "type": "number", "minimum": 0 },
        "partial_repositories": { "type": "number", "minimum": 0 },
        "failed_repositories": { "type": "number", "minimum": 0 }
      }
    },
    "global_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "scope": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "failed", "skipped"] },
          "message": { "type": "string" }
        }
      }
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repository", "status"],
        "properties": {
          "repository": { "type": "string" },
          "status": { "type": "string", "enum": ["fresh", "partial", "failed"] }
        }
      }
    }
  }
}
